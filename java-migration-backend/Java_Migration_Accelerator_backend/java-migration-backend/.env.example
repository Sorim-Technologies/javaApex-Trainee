# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# Required for higher GitHub API rate limits and private repo access.
GITHUB_TOKEN=

# Required to enable the Hugging Face-powered Java version recommendation
# and migration analysis features. Without this, the app falls back to a
# deterministic local summary automatically - it will not crash or block.
HF_TOKEN=
HF_MODEL=openai/gpt-oss-120b:fastest

# Required to enable FOSSA license/vulnerability scanning. Without this,
# FOSSA sections fall back to a simulated/skipped result automatically.
FOSSA_API_KEY=
FOSSA_PROJECT_LOCATOR=

# Optional: SonarQube integration
SONARQUBE_URL=
SONARQUBE_TOKEN=

# Optional: working directory for cloned repos during migration
WORK_DIR=
